# ── Switch ─────────────────────────────────────────────────────────
switch:
  host: ""               # Arista switch management IP — fill this in
  user: ""               # eAPI + SSH username — fill this in
  pass: ""               # password — fill this in
  interface: "mirror0"   # SPAN/mirror interface name on the switch
  ssh_port: 22
  verify_ssl: false      # EOS uses self-signed certs

# ── Capture ────────────────────────────────────────────────────────
capture:
  duration_sec: 3600     # one hour per pcap
  retry_wait_sec: 15
  base_dir: ""           # Windows path where pcaps are saved
                         # e.g. C:\Users\YourName\Desktop\pcaps
                         # Automatically converted to /mnt/c/... in WSL

# ── Feature extraction ─────────────────────────────────────────────
sasplite:
  geoip_asn_db:  "/usr/share/GeoIP/GeoLite2-ASN.mmdb"
  geoip_city_db: "/usr/share/GeoIP/GeoLite2-City.mmdb"
  subflow_gap_s: 1.0     # silence gap that ends an active burst (seconds)

# ── Aggregation ────────────────────────────────────────────────────
aggregation:
  host_profile_window_min: 10
  business_hours_start: 8
  business_hours_end: 20

# ── eAPI polling ───────────────────────────────────────────────────
eapi:
  poll_interval_s: 30
  timeout_s: 5

# ── sFlow listener ─────────────────────────────────────────────────
sflow:
  listen_port: 6343
  parse_interval_s: 60

# ── Output paths ───────────────────────────────────────────────────
paths:
  output_base:  "/data/nids/output"
  flows_dir:    "/data/nids/output/flows"
  profiles_dir: "/data/nids/output/host_profiles"
  network_ts:   "/data/nids/output/network_ts.csv"
  eapi_out:     "/data/nids/collectors/eapi_poll.csv"
  sflow_out:    "/data/nids/collectors/iface_counters.csv"
  logs:         "/var/log/nids"

# ── Retention ──────────────────────────────────────────────────────
retention:
  keep_pcaps_days: 7
  keep_csvs_days:  30

# ── Process control ────────────────────────────────────────────────
daemons:
  capture: true
  eapi:    true
  sflow:   true

# ── Timeouts ───────────────────────────────────────────────────────
timeouts:
  extractor_s:  3600
  aggregator_s: 300
  build_ts_s:   300
